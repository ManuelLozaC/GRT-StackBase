APP_NAME=GRT-StackBase
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=10
CORE_METRICS_ENABLED=false
CORE_HTTP_METRICS_ENABLED=false
CORE_SECURITY_LOGS_ENABLED=true
CORE_SECURITY_INFO_LOGS_ENABLED=false
CORE_AUDIT_LOGS_ENABLED=true

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=grt_stackbase
DB_USERNAME=grt_user
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

AUTH_COOKIE_NAME=stackbase_access_token
AUTH_COOKIE_TTL_MINUTES=480
AUTH_COOKIE_PATH=/
AUTH_COOKIE_DOMAIN=localhost
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
FILESYSTEM_FALLBACK_DISK=local
DATA_EXPORTS_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="notificaciones@soporte.grt.technology"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sfo3
AWS_BUCKET=grtbucket
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=https://sfo3.digitaloceanspaces.com
AWS_URL=https://grtbucket.sfo3.digitaloceanspaces.com

DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=sfo3
DO_SPACES_BUCKET=grtbucket
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_URL=https://grtbucket.sfo3.digitaloceanspaces.com

SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:8080
SESSION_DOMAIN=localhost
FRONTEND_URL=http://localhost:5173
WEBHOOK_REPLAY_WINDOW_SECONDS=300
WEBHOOK_REQUIRE_TIMESTAMP=true
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

MEILI_HOST=http://search:7700
MEILI_MASTER_KEY=grt-meili-local
SEARCH_ENGINE=database
MEILI_INDEX_PREFIX=grt_stackbase_
MEILI_TIMEOUT_SECONDS=5

VITE_APP_NAME="${APP_NAME}"
